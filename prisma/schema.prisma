// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Roles {
  ADMIN
  USER
}

enum Oceans {
  OCEAN_ATLANTIQUE
  OCEAN_PACIFIQUE
  OCEAN_INDIEN
  OCEAN_ARCTIQUE
  OCEAN_AUSTRAL
}

enum Uicn {
  ETEINTE_MONDIAL
  ETEINTE_SAUVAGE
  ETEINTE_REGIONAL
  EN_DANGER_CRITIQUE
  EN_DANGER
  VULNERABLE
  QUASI_MENACEE
  PREOCCUPATION_MINEURE

  DONNEES_INSUFISANTES
  NON_APPLICABLE
  NON_EVALUEE

  NON_RENSEIGNE
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  pseudo    String?
  created_at DateTime @default(now())
  role      Roles    @default(USER)
  Fish      Fish[]
}

model Fish {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // DATA INFORMATIONS
  user       User     @relation(fields: [user_id], references: [id])
  user_id    String   @db.ObjectId
  created_at DateTime @default(now())
  upadted_at DateTime @default(now())

  // GLOBAL INFORMATIONS
  name            String
  vernacular_name String
  longevity       Int?
  pictures        String[]
  UICN_category   Uicn     @default(NON_RENSEIGNE)
  description     String?

  // Morphologie
  width_max  Float
  width_min  Float
  height_max Float
  height_min Float
  motif      String?
  shape      String?

  // CLASSIFICATION = rang taxinomique
  kingdom    String @default("N/A")
  phylum     String
  class      String
  order      String
  infraOrder String @default("N/A")
  family     String
  sub_family String @default("N/A")
  genus      String
  species    String

  // MODE DE VIE
  sociability     String?
  temperature_min Int?
  temperature_max Int?
  depth_max       Int?
  depth_min       Int?
  diet            String?
  venomous        Boolean?
  // Ajouter courants + Type d'eau + Terrotorialité + Diurne/nocture/both

  // LOCALISATION
  ocean_localisation Oceans[]
  // Ajouter Lac + Rivières 

  // AQUARIOPHILIE
}
